---
import Header from "../components/Header.astro";
import Project from "../components/Project.astro";
import Sidebar from "../components/Sidebar.astro";
import "../styles/styles.css";

const projects = [
  {
    title: "MATI - Telemetry System",
    desc: [
      "Leading the design and development of a real-time telemetry application for a Formula SAE racing team",
      "Implementing data visualization systems to monitor vehicle performance and sensor health during testing",
      "Managing project architecture and versioning, successfully reaching version 1.4.2 with stable deployments",
      "Coordinating cross-functional efforts to integrate hardware data pipelines with a web-based dashboard",
    ],
    tech: ["Python", "JavaScript", "Node.js", "GitHub"],
  },
];
---

<!doctype html>
<html>
  <Header title="Software Development | Alejandro Ramírez" />
  <body>
    <div class="content">
      <Sidebar selectedItem="software-development" />
      <nav class="main">
        <div class="container">
          <div class="back-nav-container">
            <a href="/" class="back-nav-button w-inline-block"
              ><img
                src="/assets/back.svg"
                loading="lazy"
                alt=""
                class="back-nav-img"
              />
              <div>Back</div></a
            >
          </div>
          <div class="content-container">
            <h1>Software Development</h1>
            <section class="items-container">
              <div class="resouce-items">
                {
                  projects.map((project) => (
                    <Project
                      title={project.title}
                      desc={project.desc}
                      tech={project.tech}
                    />
                  ))
                }
              </div>
            </section>
          </div>
        </div>
      </nav>
    </div>

    <!--[if lte IE 9]><script src="//cdnjs.cloudflare.com/ajax/libs/placeholders/3.0.2/placeholders.min.js"></script><![endif]-->
  </body>
</html>
