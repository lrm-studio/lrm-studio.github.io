---
import Header from "../components/Header.astro";
import Project from "../components/Project.astro";
import Sidebar from "../components/Sidebar.astro";
import "../styles/styles.css";

const projects = [
  {
    title: "MATI v2.0 - Telemetry System [In Progress]",
    desc: [
      "Leading the development of the official telemetry and data acquisition system for the UAMOTORS Formula SAE team.",
      "Optimizing real-time sensor visualization and diagnostic dashboards for high-performance racing environments.",
      "Iterating from v1.4.2 to v2.0 to enhance data pipeline stability and cross-platform synchronization.",
      "Coordinating full-stack efforts to provide actionable performance insights for race engineering teams.",
    ],
    tech: ["Python", "React", "Node.js", "GitHub", "Figma"],
  },
];
---

<!doctype html>
<html>
  <Header title="DevOps | Alejandro Ramírez" />
  <body>
    <div class="content">
      <Sidebar selectedItem="devops" />
      <nav class="main">
        <div class="container">
          <div class="back-nav-container">
            <a href="/" class="back-nav-button w-inline-block"
              ><img
                src="/assets/back.svg"
                loading="lazy"
                alt=""
                class="back-nav-img"
              />
              <div>Back</div></a
            >
          </div>
          <div class="content-container">
            <h1>DevOps</h1>
            <section class="items-container">
              <div class="resouce-items">
                {
                  projects.map((project) => (
                    <Project
                      title={project.title}
                      desc={project.desc}
                      tech={project.tech}
                    />
                  ))
                }
              </div>
            </section>
          </div>
        </div>
      </nav>
    </div>

    <!--[if lte IE 9]><script src="//cdnjs.cloudflare.com/ajax/libs/placeholders/3.0.2/placeholders.min.js"></script><![endif]-->
  </body>
</html>
